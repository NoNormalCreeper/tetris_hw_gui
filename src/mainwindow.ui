      <layout class="QVBoxLayout" name="verticalLayout_2">
       <item>
        <widget class="QLabel" name="labelGameOver">
         <property name="styleSheet">
          <string notr="true">font-size: 90px;
    font-family: 'Fira Code', 'Consolas', 'Arial';
    font-weight: bold;
    /* color 这里不写，由Html富文本指定 */
    qproperty-alignment: 'AlignCenter';
    border: none;
    background: transparent;</string>
         </property>
         <property name="text">
          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; color:#ff1744;&quot;&gt;G&lt;/span&gt;&lt;span style=&quot; color:#ff9100;&quot;&gt;a&lt;/span&gt;&lt;span style=&quot; color:#ffea00;&quot;&gt;m&lt;/span&gt;&lt;span style=&quot; color:#00e676;&quot;&gt;e &lt;/span&gt;&lt;span style=&quot; color:#2979ff;&quot;&gt;O&lt;/span&gt;&lt;span style=&quot; color:#7c4dff;&quot;&gt;v&lt;/span&gt;&lt;span style=&quot; color:#00e5ff;&quot;&gt;e&lt;/span&gt;&lt;span style=&quot; color:#d500f9;&quot;&gt;r&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
         </property>
        </widget>
       </item>
